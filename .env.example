# Deployer wallet
PRIVATE_KEY=0x...

# RPC endpoint (Base mainnet default)
RPC_URL=https://mainnet.base.org

# TEEBridge contract address (after deployment)
BRIDGE_CONTRACT=0x...

# KMS root addresses for deployment (comma-separated)
KMS_ROOTS=0x...

# For hosted.dstack.info deployments
DSTACK_VMM_URL=https://your-dstack-instance
DSTACK_VMM_AUTH_USER=
DSTACK_VMM_AUTH_PASSWORD=
